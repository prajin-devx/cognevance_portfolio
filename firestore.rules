rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /planner_orders/{document} {
      allow read, write: if true;
    }
    match /planner-orders/{document} {
      allow read, write: if true;
    }
    match /contact_messages/{document} {
      allow read, write: if true;
    }
  }
}
